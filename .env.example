# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NVIDIA_API_KEY: Required for AI features (import, report analysis, chat).
# Only used by the backend proxy (server/index.cjs). Get your free key at https://build.nvidia.com
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"

# VITE_API_BASE: URL base do backend (API de negócio).
# Em dev, usa http://localhost:3001 automaticamente.
VITE_API_BASE="https://api-finance.geniusweb.online"

# VITE_AI_PROXY: URL do backend AI proxy em produção (VPS).
# Deixe vazio para dev (usa localhost:3001 automaticamente).
VITE_AI_PROXY="https://api-finance.geniusweb.online/api/ai/chat"

# RESEND_API_KEY: opcional para envio de email de boas-vindas.
RESEND_API_KEY=""

# RESEND_FROM: remetente validado no Resend.
RESEND_FROM="GeniusHub <onboarding@geniushub.app>"

# ABACATE_API_KEY: chave de API da AbacatePay v2.
ABACATE_API_KEY=""

# ABACATE_WEBHOOK_SECRET: secret configurado na URL do webhook.
ABACATE_WEBHOOK_SECRET=""

# FIREBASE_WEB_API_KEY: opcional para validacao do Bearer token no backend.
# Se vazio, usa apiKey do firebase-applet-config.json.
FIREBASE_WEB_API_KEY=""

# SUPERADMIN_EMAIL: Email que recebe notificações de reports.
SUPERADMIN_EMAIL=""

# FIREBASE_SERVICE_ACCOUNT_PATH: Caminho para o JSON da service account (Firebase Admin SDK).
# Ex: server/service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=""
